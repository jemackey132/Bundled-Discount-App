<style>
  #super-bundle-data{
    display: flex;
    justify-content: center;
    text-align: center;
  }
  
  .product-tile {
    width: 200px;
    height: 200px;
    background-color: #ffffff;
    border: 1px solid #000000;
    margin: 10px;
  }

  .product-image {
    width: 100px;
    height: 100px;
  }

  .product-title {
    font-size: 16px;
    text-align: center;
  }

  .product-price {
    font-size: 14px;
    text-align: center;
  }
</style>

<super-bundle id="super-bundle-data"></super-bundle>

<script>
  var product = {{ product | json }}

  function appendProductTile(title, imageSrc, price) {
    const productTile = document.createElement("div");
    productTile.classList.add("product-tile");

    const productImage = document.createElement("img");
    productImage.src = imageSrc;
    productImage.alt = "Product Image";
    productImage.classList.add('product-image');

    const productTitle = document.createElement("h3");
    productTitle.textContent = title;

    const productPrice = document.createElement("p");
    productPrice.textContent = price;

    productTile.appendChild(productImage);
    productTile.appendChild(productTitle);
    productTile.appendChild(productPrice);

    document.getElementById("super-bundle-data").appendChild(productTile);
  }

  let formData = new FormData();
  formData.append('product_id', product.id);

  var options = {
    method:"POST",
    body:formData
  };

  fetch("/apps/proxy",options)
  .then((res) => res.json())
  .then((data) => {
    console.log(data)
    var productData = data.responseJson.data.product

    var hasDefault = productData.hasOnlyDefaultVariant

    var productVariant = productData.variants.nodes

    var hasComponents = productVariant[0].requiresComponents

    if(hasComponents){
      var componentData = productVariant[0].productVariantComponents.nodes

      for(let component of componentData){
        var title = component.productVariant.displayName;
        var image = component.productVariant.image ? component.productVariant.image.url: "";
        var price = component.productVariant.price;

        var componentDefault = component.productVariant.product.hasOnlyDefaultVariant

        if(componentDefault){
          title = component.productVariant.product.title
        }
        if(image == ""){
          image = component.productVariant.product.featuredImage ? component.productVariant.product.featuredImage.url: ""
        }

        appendProductTile(title,image,price)
      }
    }

  })
</script>
{% schema %}
{
  "name": "Bundle Variant Picker",
  "target": "section",
  "settings": []
}
{% endschema %}
