// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Session {
  id          String    @id
  shop        String
  state       String
  isOnline    Boolean   @default(false)
  scope       String?
  expires     DateTime?
  accessToken String
  userId      BigInt?
}

model Bundle {
  id                    Int      @id @default(autoincrement())
  shop                  String
  bundle_title          String   @unique
  bundle_type           String
  bundle_name           String
  bundle_image          String
  bundle_discount       Boolean  @default(true)
  bundle_discount_type  String
  bundle_discount_value String
  bundle_status         Boolean  @default(true)
  bundle_items          Json
  bundle_time_status    Boolean  @default(false)
  bundle_start_time     String
  bundle_start_date     String
  bundle_end_status     Boolean  @default(false)
  bundle_end_time       String
  bundle_end_date       String
  bundle_views          Int      @default(0)
  bundle_clicks         Int      @default(0)
  bundle_orders         Int      @default(0)
  bundle_sales          Float    @default(0)
  bundle_gid            String?  @unique
  bundle_handle         String?
  bundle_price          String?
  bundle_currency       String?
  bundle_discount_price String?
  bundle_media          String?  @db.Text
  created_at            DateTime @default(now()) @map("created_at")
  updated_at            DateTime @updatedAt @map("updated_at")
}

model VolumeDiscount {
  id             Int          @id @default(autoincrement())
  shop           String
  title          String
  status         Boolean      @default(true)
  product_id     String
  product_title  String
  product_image  String?
  discount_gid   String?
  views          Int          @default(0)
  orders         Int          @default(0)
  revenue        Float        @default(0)
  tiers          VolumeTier[]
  created_at     DateTime     @default(now()) @map("created_at")
  updated_at     DateTime     @updatedAt @map("updated_at")
}

model VolumeTier {
  id                 Int            @id @default(autoincrement())
  volume_discount_id Int
  volume_discount    VolumeDiscount @relation(fields: [volume_discount_id], references: [id], onDelete: Cascade)
  min_quantity       Int
  discount_type      String
  discount_value     Float
  label              String?
  created_at         DateTime       @default(now()) @map("created_at")
}

model BundleEvent {
  id         Int      @id @default(autoincrement())
  bundle_id  Int
  shop       String
  event_type String   // "view" | "click" | "order"
  value      Float    @default(0)
  offer_type String?  // "bundle" | "volume_discount" | "bogo" — null = legacy bundle event
  offer_id   Int?     // FK to the specific offer row
  created_at DateTime @default(now()) @map("created_at")

  @@index([shop, event_type, created_at])
  @@index([bundle_id])
  @@index([shop, offer_type, offer_id])
}

model BuyXGetY {
  id                  Int      @id @default(autoincrement())
  shop                String
  title               String
  status              Boolean  @default(true)
  buy_product_id      String
  buy_product_title   String
  buy_product_image   String?
  buy_quantity        Int      @default(1)
  get_product_id      String
  get_product_title   String
  get_product_image   String?
  get_quantity        Int      @default(1)
  discount_value      Float    @default(100)
  created_at          DateTime @default(now()) @map("created_at")
  updated_at          DateTime @updatedAt @map("updated_at")

  @@index([shop])
}

model AppSetting {
  id         Int      @id @default(autoincrement())
  shop       String
  key        String
  value      String   @db.Text
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@unique([shop, key], name: "shop_key")
}

model BundleSettings {
  id                    Int     @id @default(autoincrement())
  shop                  String  @unique
  subscriptions_enabled Boolean @default(false)
  track_inventory       Boolean @default(false)
  track_inventory_mode  String  @default("disabled")
  button_action         String  @default("cart")
  variant_selector      String  @default("color_swatch")
  product_pricing       String  @default("final_price")
  discount_application  String  @default("when_click")
  discount_combination  String  @default("when_click")
  translations          String  @default("{}") @db.VarChar(2000)
  created_at            DateTime @default(now()) @map("created_at")
  updated_at            DateTime @updatedAt @map("updated_at")
}
